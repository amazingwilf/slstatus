#!/bin/sh

# Prints the current volume or đź”‡ if muted.

vol="$(wpctl get-volume @DEFAULT_AUDIO_SINK@)"

# If muted, print đź”‡ and exit.
[ "$vol" != "${vol%\[MUTED\]}" ] && echo "^C01^ó°ťź  Muted  ^d^" && exit

vol="${vol#Volume: }"

split() {
	# For ommiting the . without calling and external program.
	IFS=$2
	set -- $1
	printf '%s' "$@"
}

vol="$(printf "%.0f" "$(split "$vol" ".")")"

case 1 in
	$((vol >= 70)) ) icon="^C05^ď€¨ ^d^" ;;
	$((vol >= 30)) ) icon="^C05^ó°•ľ ^d^" ;;
	$((vol >= 1)) ) icon="^C05^ó°–€ ^d^" ;;
	* ) icon="^C05^ó°–€ ^d^" ;;
esac

echo "$icon  $vol% "
